#!/bin/sh
# Pre-commit hook: validate notes against repo conventions before committing.
# Blocks the commit on errors (schema violations); warnings are advisory.
# Run `git config core.hooksPath scripts/hooks` once to enable (or scripts/install-hooks.sh).

repo_root=$(git rev-parse --show-toplevel)

# Errors block the commit; warnings are advisory (see full report with
# `python3 scripts/lint-notes.py`).
python3 "$repo_root/scripts/lint-notes.py" --errors-only
status=$?

if [ "$status" -ne 0 ]; then
    echo
    echo "Commit blocked: fix the errors above, or run 'git commit --no-verify' to bypass."
fi

exit "$status"
